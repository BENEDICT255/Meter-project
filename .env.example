SECRET_KEY=change-me-in-real-deploys
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

DB_NAME=daraja
DB_USER=daraja
DB_PASSWORD=daraja
DB_HOST=127.0.0.1
DB_PORT=3306

WEBHOOK_HMAC_SECRET=dev-webhook-secret-change-me

# Swahilies (payment provider)
SWAHILIES_API_URL=https://swahiliesapi.invict.site/Api
SWAHILIES_API_KEY=replace-me
SWAHILIES_IS_LIVE=False
SWAHILIES_WEBHOOK_URL=http://localhost:8000/api/webhooks/payment/

# TOKEN_STRATEGY: "simple" (reversible, for Arduino prototypes) or "hmac" (production)
TOKEN_STRATEGY=simple
TOKEN_SIMPLE_MULTIPLIER=1357
TOKEN_HMAC_SECRET=dev-token-secret-change-me
TOKEN_HMAC_DIGITS=12

SMS_PROVIDER=console
# To use MalipoPay instead of the console logger, set SMS_PROVIDER=malipopay and fill in:
MALIPOPAY_API_URL=https://core-prod.malipopay.co.tz/api/v1/sms
MALIPOPAY_API_TOKEN=replace-me
MALIPOPAY_SENDER=Daraja
MALIPOPAY_OPERATOR_ID=replace-me

TRANSACTION_TTL_MINUTES=30

CORS_ALLOWED_ORIGINS=http://localhost:3000
